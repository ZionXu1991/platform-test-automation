{
  "name": "platform-test-automation",
  "version": "1.0.0",
  "description": "AI-powered Cypress test automation for platform-server and platform-web",
  "type": "commonjs",
  "scripts": {
    "automate": "node scripts/run-automation.js",
    "generate": "node scripts/run-automation.js --generate-only",
    "test": "cypress run",
    "test:open": "cypress open",
    "test:generated": "cypress run --spec 'cypress/e2e/generated/**/*.cy.js'",
    "test:baseline": "cypress run --spec 'cypress/e2e/baseline/**/*.cy.js'",
    "test:report": "npx mochawesome-merge cypress/reports/*.json -o cypress/reports/combined.json && npx marge cypress/reports/combined.json -o cypress/reports/html"
  },
  "dependencies": {
    "openai": "^4.47.0",
    "simple-git": "^3.24.0",
    "dotenv": "^16.4.5",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "ora": "^5.4.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "cypress": "^13.11.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
