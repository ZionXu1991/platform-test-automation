# ─────────────────────────────────────────────────────────────────
# platform-test-automation — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────

# ─── AI Provider ─────────────────────────────────────────────────
# Choose: "openai" | "azure"
AI_PROVIDER=openai

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Azure OpenAI (if AI_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ─── Source Repositories ─────────────────────────────────────────
# Absolute paths to your local repo clones
PLATFORM_SERVER_REPO=/path/to/platform-server
PLATFORM_WEB_REPO=/path/to/platform-web

# ─── Test Target Environment ──────────────────────────────────────
# Frontend base URL (Cypress baseUrl)
CYPRESS_BASE_URL=http://localhost:3000

# Backend API base URL (for cy.request() API tests)
API_BASE_URL=http://localhost:8080

# ─── Test Credentials ─────────────────────────────────────────────
TEST_USERNAME=test@example.com
TEST_PASSWORD=Test@123
AUTH_HEADER=Authorization

# ─── Git Diff Options ─────────────────────────────────────────────
# Default: diff from last commit. Override with a specific commit SHA or range.
# Examples: "HEAD~1", "abc123..def456", "main..feature/my-feature"
DEFAULT_DIFF_RANGE=HEAD~1

# ─── Output ───────────────────────────────────────────────────────
# Where to write generated test files (relative to project root)
GENERATED_TESTS_DIR=cypress/e2e/generated

# Verbose logging (true | false)
VERBOSE=false
