# ─────────────────────────────────────────────────────────────────
# platform-test-automation — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────

# ─── Source Repositories ─────────────────────────────────────────
# Absolute paths to your local repo clones
PLATFORM_SERVER_REPO=/path/to/platform-server
PLATFORM_WEB_REPO=/path/to/platform-web

# ─── Test Target Environment ──────────────────────────────────────
# Frontend base URL (Cypress baseUrl)
CYPRESS_BASE_URL=http://localhost:3000

# Backend API base URL (for cy.request() API tests)
API_BASE_URL=http://localhost:8080

# ─── Test Credentials ─────────────────────────────────────────────
TEST_USERNAME=test@example.com
TEST_PASSWORD=Test@123

# ─── Git Diff Options ─────────────────────────────────────────────
# Default diff range. Examples: "HEAD~1", "main..feature/my-feature"
DEFAULT_DIFF_RANGE=HEAD~1
