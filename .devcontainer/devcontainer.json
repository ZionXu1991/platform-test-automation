{
  "name": "Platform Test Automation",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "mounts": [
    "source=${localWorkspaceFolder}/../platform-server,target=/workspaces/platform-server,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/../platform-web,target=/workspaces/platform-web,type=bind,consistency=cached"
  ],

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "forwardPorts": [3000, 8080],

  "remoteEnv": {
    "PLATFORM_SERVER_REPO": "/workspaces/platform-server",
    "PLATFORM_WEB_REPO": "/workspaces/platform-web",
    "CYPRESS_BASE_URL": "http://localhost:3000",
    "API_BASE_URL": "http://localhost:8080",
    "AUTOMATION_ROOT": "${containerWorkspaceFolder}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  }
}
